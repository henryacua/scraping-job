# ===========================================
# scraping-job-ms — Environment Variables
# ===========================================

# ── Base de datos ────────────────────────────────────────
# Producción (Supabase): URI con driver async, p. ej.
#   DATABASE_URL=postgresql+asyncpg://postgres:CONTRASEÑA@db.xxx.supabase.co:5432/postgres
# Si la contraseña tiene @ : # / % etc., codifícala: python -c "from urllib.parse import quote_plus; print(quote_plus('tu_clave'))"
# El host directo db.<ref>.supabase.co suele ser SOLO IPv6. Sin IPv6 (muchas redes / Render),
# falla DNS o "Network is unreachable". Usa el string del POOLER en el panel de Supabase:
#   host ~ aws-0-<REGION>.pooler.supabase.com, puerto 6543 (transaction) o 5432 (session)
# Usuario pooler a veces es postgres.<PROJECT_REF> — copia la URI exacta del dashboard.
# DATABASE_URL=postgresql+asyncpg://postgres.<ref>:CODIFICADA@aws-0-REGION.pooler.supabase.com:6543/postgres
# Puedes pegar postgresql://... desde Supabase; se convierte a postgresql+asyncpg automáticamente.
# Si ves CERTIFICATE_VERIFY_FAILED en Mac, ejecuta Install Certificates.command del Python
# o solo en local: DATABASE_SSL_INSECURE=true (no uses eso en producción si puedes evitarlo).
DATABASE_SSL_INSECURE=false
# Local (SQLite async; arranca uvicorn/streamlit desde la raíz del repo):
DATABASE_URL=sqlite+aiosqlite:///./queue.db

# ── API interna (comunicación Streamlit Cloud → Render) ──
# URL pública del Web Service en Render (sin / al final)
RENDER_API_URL=https://scraping-job-ms.onrender.com
# Clave compartida: genera una string aleatoria larga y ponla igual en Render y Streamlit Cloud
API_KEY=

# ── Búsqueda ─────────────────────────────────────────────
SEARCH_QUERY="Dentistas en Medellín"

# ── Playwright / Scraper ─────────────────────────────────
HEADLESS=true
MAX_SCROLL_ATTEMPTS=20
SCROLL_PAUSE_SECONDS=2

# ── Verificación HTTP ────────────────────────────────────
HTTP_TIMEOUT=10
BATCH_SIZE=10

# ── Salida (solo aplica si usas estrategia SaveToCSV) ────
OUTPUT_DIR=output

# ── WhatsApp Business Cloud API ──────────────────────────
# Obtener en: https://developers.facebook.com → WhatsApp → API Setup
WA_API_TOKEN=
WA_PHONE_NUMBER_ID=
WA_API_VERSION=v21.0
WA_TEMPLATE_NAME=hello_world
WA_TEMPLATE_LANG=es
WA_SEND_DELAY_MIN=1.5
WA_SEND_DELAY_MAX=3.0

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
